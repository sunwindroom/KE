# 复制为 .env 后按需修改，不要把 .env 提交到 git（已在 .gitignore 中排除）。
# JWT_SECRET_KEY 是必填项，docker-compose 会在未设置时直接拒绝启动。
# 生成一个随机密钥：openssl rand -hex 32
JWT_SECRET_KEY=

POSTGRES_PASSWORD=phm123
NEO4J_PASSWORD=neo4j123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
RABBITMQ_PASSWORD=guest

# 前端可访问的后端地址，以及跨域白名单（JSON 数组字符串）
VITE_API_BASE_URL=http://localhost:8000/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# 生产部署建议设为 false（默认）；本地调试可设为 true 打开 /docs
BACKEND_DEBUG=false
LOG_LEVEL=INFO
