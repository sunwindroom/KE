# ============================================================================
# 首次部署的初始值 / 兜底默认值。
#
# 自 2026-07 起，除本文件外，系统新增了「系统设置」界面（管理员登录后访问 /settings），
# 可以在浏览器里直接维护大模型 API、向量模型 API、登录安全策略、上传限流、
# 以及数据库/图数据库/向量库/对象存储/缓存/消息队列的连接信息——不再需要登录服务器
# 修改这个文件。界面上保存的值会存入数据库并覆盖下面的默认值：
#   - 大模型/向量模型/安全策略/上传限流：保存后立即生效，无需重启。
#   - 数据库/图数据库/向量库/对象存储/缓存/消息队列/CORS：保存后需要重启后端容器才能生效
#     （因为这些连接池只在进程启动时建立一次）。
#
# 也就是说：这份 .env 只需要提供“容器第一次启动时”的初始值，
# 后续调参统一去 /settings 页面完成即可。
# ============================================================================
DATABASE_URL=postgresql+asyncpg://phm:phm123@localhost:5432/phm_ke
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123
MILVUS_HOST=localhost
MILVUS_PORT=19530
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# 必须设置为随机高强度密钥（openssl rand -hex 32）。它既用于签发登录令牌，
# 也用于加密“系统设置”里保存的各类密钥，请务必妥善保管、不要随意更换。
JWT_SECRET_KEY=change-me-in-production
# 以下大模型/向量模型配置可以留空——留空时系统会自动降级为规则化实现，
# 部署完成后可直接在「系统设置 → 大模型 API / 向量模型 API」里填写并测试连接。
LLM_ENDPOINT=http://localhost:8001/v1
LLM_API_KEY=
LLM_MODEL_NAME=qwen2.5-72b-instruct
EMBEDDING_ENDPOINT=http://localhost:8002/v1

# 生产部署建议：DEBUG=false，EXPOSE_API_DOCS=false（关闭 /docs /redoc 公开访问）
DEBUG=false
EXPOSE_API_DOCS=true
LOG_LEVEL=INFO

# 登录失败锁定（防暴力破解）
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15